{
  "name": "model-print-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "yarn dev:api & yarn dev:web & wait",
    "dev:api": "yarn workspace @model-print/api dev",
    "dev:web": "yarn workspace @model-print/web dev",
    "build:api": "yarn workspace @model-print/api build",
    "build:web": "yarn workspace @model-print/web build",
    "build": "yarn build:api && yarn build:web",
    "start:api": "yarn workspace @model-print/api start",
    "preview:web": "yarn workspace @model-print/web preview",
    "lint:web": "yarn workspace @model-print/web lint",
    "test:web": "yarn workspace @model-print/web test",
    "db:generate": "yarn workspace @model-print/api db:generate",
    "db:migrate": "yarn workspace @model-print/api db:migrate",
    "db:push": "yarn workspace @model-print/api db:push"
  },
  "engines": {
    "node": ">=20"
  }
}
